<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/colorBorder"
    app:cardBackgroundColor="@color/colorCardBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image Container with Rating Badge Overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <ImageView
                android:id="@+id/houseImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/image"
                android:contentDescription="Property Image" />

            <!-- Rating Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_rating_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/houseRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="★ 4.8"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Category Tag -->
            <TextView
                android:id="@+id/houseCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apartment"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@color/colorSecondary"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_gravity="bottom|start"
                android:layout_margin="12dp" />

        </FrameLayout>

        <!-- Listing Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/housePrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$120 / night"
                android:textColor="@color/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/houseTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cozy Modern Downtown Studio"
                android:textColor="@color/colorOnBackground"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1" />

            <!-- Location with Icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_menu_mapmode"
                    app:tint="@color/colorTextSecondary"
                    android:contentDescription="Map icon" />

                <TextView
                    android:id="@+id/houseLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="New York, USA"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    android:layout_marginStart="4dp"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
