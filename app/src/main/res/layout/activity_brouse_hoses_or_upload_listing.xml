<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".MainActivity">

    <!-- App Title -->
    <TextView
        android:id="@+id/welcomeTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Find your dream home with ApartmentRenter"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:lineSpacingExtra="6dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Button 1: Browse Houses -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBrowseHouses"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="Browse Houses for Rent"
        android:textSize="16sp"
        android:layout_marginTop="40dp"
        android:backgroundTint="#1E3A8A"
        android:textColor="@android:color/white"
        app:icon="@android:drawable/ic_menu_search"
        app:iconGravity="textStart"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/welcomeTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Button 2: Upload Listing -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUploadListing"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="List Your Property"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#0D9488"
        android:textColor="@android:color/white"
        app:icon="@android:drawable/ic_menu_add"
        app:iconGravity="textStart"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnBrowseHouses"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Decorative Illustration -->
    <ImageView
        android:id="@+id/mainIllustration"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnUploadListing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/image" />

</androidx.constraintlayout.widget.ConstraintLayout>