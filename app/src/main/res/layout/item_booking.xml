<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/colorBorder"
    app:cardBackgroundColor="@color/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Property Thumbnail Image -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardCornerRadius="8dp"
            app:strokeWidth="0dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/bookingImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/image"
                android:contentDescription="Property Thumbnail" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Booking details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/bookingTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Malibu Beach Villa"
                android:textColor="@color/colorOnBackground"
                android:textSize="14sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/bookingLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Malibu, California"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/bookingDateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Booked: June 6, 2026"
                android:textColor="@color/colorPrimary"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Booking Price -->
        <TextView
            android:id="@+id/bookingPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$450"
            android:textColor="@color/colorSecondary"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
